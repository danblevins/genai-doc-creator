<div class="doc quarterly-review">
  <div class="doc-cover doc-page">
    <div class="doc-cover-visual">
      <svg class="doc-cover-icon doc-cover-icon--chart" viewBox="0 0 100 70" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M10 50 L10 50 L25 42 L40 45 L55 28 L70 32 L85 18 L85 58 L10 58 Z" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
        <line x1="10" y1="50" x2="25" y2="42" stroke="currentColor" stroke-width="2"/>
        <line x1="25" y1="42" x2="40" y2="45" stroke="currentColor" stroke-width="2"/>
        <line x1="40" y1="45" x2="55" y2="28" stroke="currentColor" stroke-width="2"/>
        <line x1="55" y1="28" x2="70" y2="32" stroke="currentColor" stroke-width="2"/>
        <line x1="70" y1="32" x2="85" y2="18" stroke="currentColor" stroke-width="2"/>
        <circle cx="10" cy="50" r="3" fill="currentColor"/>
        <circle cx="25" cy="42" r="3" fill="currentColor"/>
        <circle cx="40" cy="45" r="3" fill="currentColor"/>
        <circle cx="55" cy="28" r="3" fill="currentColor"/>
        <circle cx="70" cy="32" r="3" fill="currentColor"/>
        <circle cx="85" cy="18" r="3" fill="currentColor"/>
      </svg>
    </div>
    <h1 class="doc-cover-title">{{orgName}}</h1>
    <p class="doc-cover-subtitle">{{period}} · Business / Organization Review</p>
  </div>
  <div class="doc-page-break" aria-hidden="true"></div>
  <div class="doc-page doc-page-content">
    <section class="doc-section">
      <div class="doc-section-header">
        <span class="doc-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg></span>
        <h2 class="doc-heading">Highlights / Wins</h2>
      </div>
      <div class="doc-content">{{{highlights}}}</div>
    </section>
    {{#if metrics.length}}
    <section class="doc-section">
      <div class="doc-section-header">
        <span class="doc-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg></span>
        <h2 class="doc-heading">Key Metrics</h2>
      </div>
      <div class="doc-metrics-viz" aria-label="Metrics at a glance">
        <div class="doc-metrics-overall">
          <span class="doc-metrics-overall-label">Overall progress</span>
          <div class="doc-metric-bar-track doc-metric-bar-track--overall">
            <div class="doc-metric-bar-fill doc-metric-bar-fill--accent" style="width: {{averageBarPct metrics}}%;"></div>
          </div>
          <span class="doc-metrics-overall-value">{{averageBarPct metrics}}% of target</span>
        </div>
        <div class="doc-metrics-chart">
          {{#each metrics}}
          <div class="doc-metric-bar-row">
            <span class="doc-metric-bar-label">{{this.metric}}</span>
            <div class="doc-metric-bar-track">
              <div class="doc-metric-bar-fill" style="width: {{metricBarPct this.actual this.target}}%;"></div>
            </div>
            <span class="doc-metric-bar-legend">{{this.actual}} / {{this.target}}</span>
          </div>
          {{/each}}
        </div>
      </div>
      <table class="doc-table">
        <thead>
          <tr><th>Metric</th><th>Target</th><th>Actual</th><th>Note</th></tr>
        </thead>
        <tbody>
          {{#each metrics}}
          <tr>
            <td>{{this.metric}}</td>
            <td>{{this.target}}</td>
            <td>{{this.actual}}</td>
            <td>{{this.note}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </section>
    {{/if}}
    <section class="doc-section">
      <div class="doc-section-header">
        <span class="doc-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg></span>
        <h2 class="doc-heading">Challenges / Risks</h2>
      </div>
      <div class="doc-content">{{{challenges}}}</div>
    </section>
    <section class="doc-section">
      <div class="doc-section-header">
        <span class="doc-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></span>
        <h2 class="doc-heading">Priorities for Next Period</h2>
      </div>
      <div class="doc-content">{{{priorities}}}</div>
    </section>
    <section class="doc-section">
      <div class="doc-section-header">
        <span class="doc-section-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg></span>
        <h2 class="doc-heading">Support Needed</h2>
      </div>
      <div class="doc-content">{{{supportNeeded}}}</div>
    </section>
  </div>
</div>
